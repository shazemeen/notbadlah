---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Not Bad Lah | Earn Extra RM5,000/Month Part-Time in Malaysia",
  description = "Can you really earn RM5,000 extra per month, part-time? We showed people on the street. Their reaction? 'Insurance... not bad lah!' Find out how with AIA Malaysia.",
  ogImage = "https://notbadlah.com/og-image.jpg"
} = Astro.props;
---

<!doctype html>
<html lang="en-MY">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="part-time job Malaysia, extra income Malaysia, kerja sambilan Malaysia, side income KL, earn money part-time, AIA agent Malaysia, insurance agent part-time, part-time work from home Malaysia, how to earn 5000 a month Malaysia, pendapatan sampingan Malaysia" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://notbadlah.com" />
    <meta name="author" content="Charles Shazemeen" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://notbadlah.com" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_MY" />
    <meta property="og:site_name" content="notbadlah.com" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />

    <!-- Schema.org structured data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "notbadlah.com",
      "description": "Part-time insurance agent opportunity in Malaysia. Earn RM5,000-RM10,000 extra per month.",
      "url": "https://notbadlah.com",
      "publisher": {
        "@type": "Person",
        "name": "Charles Shazemeen",
        "url": "https://shazemeen.com",
        "jobTitle": "Unit Manager, AIA Malaysia"
      },
      "mainEntity": {
        "@type": "JobPosting",
        "title": "Part-Time Insurance Agent",
        "description": "Earn extra RM5,000–RM10,000 per month as a part-time AIA insurance agent in Malaysia. No experience required. Flexible hours.",
        "hiringOrganization": {
          "@type": "Organization",
          "name": "AIA Malaysia"
        },
        "jobLocationType": "TELECOMMUTE",
        "employmentType": "PART_TIME",
        "jobLocation": {
          "@type": "Place",
          "address": {
            "@type": "PostalAddress",
            "addressCountry": "MY"
          }
        },
        "baseSalary": {
          "@type": "MonetaryAmount",
          "currency": "MYR",
          "value": {
            "@type": "QuantitativeValue",
            "minValue": 5000,
            "maxValue": 10000,
            "unitText": "MONTH"
          }
        }
      }
    }
    </script>
  </head>
  <body class="grain-overlay">
    <slot />
  </body>
</html>
