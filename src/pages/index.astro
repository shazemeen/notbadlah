  </footer>
</Layout>

<!-- ===== SCRIPTS ===== -->
<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Nav scroll effect
  const nav = document.getElementById('nav');
  ScrollTrigger.create({
    start: 'top -80',
    onUpdate: (self) => {
      if (nav) {
        nav.style.background = self.progress > 0 ? 'rgba(8,8,8,0.95)' : 'transparent';
        nav.style.backdropFilter = self.progress > 0 ? 'blur(12px)' : 'none';
        nav.style.borderBottom = self.progress > 0 ? '1px solid #111' : 'none';
      }
    }
  });

  // Fade up animations
  gsap.utils.toArray('.fade-up').forEach((el: any) => {
    gsap.fromTo(el,
      { opacity: 0, y: 40 },
      {
        opacity: 1, y: 0,
        duration: 0.8,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 88%',
          toggleActions: 'play none none none'
        }
      }
    );
  });

  // Hero entrance
  gsap.from('#hero h1', { opacity: 0, y: 60, duration: 1.2, ease: 'power4.out', delay: 0.2 });
  gsap.from('#hero p', { opacity: 0, y: 40, duration: 1, ease: 'power3.out', delay: 0.4 });
  gsap.from('#hero .flex', { opacity: 0, y: 30, duration: 0.8, ease: 'power3.out', delay: 0.6 });

  // Chat messages stagger
  ScrollTrigger.create({
    trigger: '#chat-container',
    start: 'top 70%',
    onEnter: () => {
      gsap.utils.toArray('.chat-msg').forEach((el: any, i) => {
        gsap.fromTo(el,
          { opacity: 0, x: el.classList.contains('justify-end') ? 40 : -40 },
          { opacity: 1, x: 0, duration: 0.5, delay: i * 0.15, ease: 'power2.out' }
        );
      });
    }
  });

  // Income calculator logic
  const contactsSlider = document.getElementById('contacts-slider') as HTMLInputElement;
  const hoursSlider = document.getElementById('hours-slider') as HTMLInputElement;
  const contactsDisplay = document.getElementById('contacts-display');
  const hoursDisplay = document.getElementById('hours-display');
  const calcResult = document.getElementById('calc-result');
  const bdMeetings = document.getElementById('bd-meetings');
  const bdPolicies = document.getElementById('bd-policies');

  function updateCalc() {
    const contacts = parseInt(contactsSlider?.value || '10');
    const hours = parseInt(hoursSlider?.value || '10');

    if (contactsDisplay) contactsDisplay.textContent = String(contacts);
    if (hoursDisplay) hoursDisplay.textContent = String(hours);

    // Calculation: meetings/month, 20% conversion, RM750 avg commission
    const meetingsPerMonth = Math.round(contacts * 4.3);
    // More hours = slightly better conversion (engagement quality)
    const conversionRate = Math.min(0.20 + (hours - 5) * 0.003, 0.30);
    const policies = Math.max(1, Math.round(meetingsPerMonth * conversionRate));
    const income = policies * 750;

    if (bdMeetings) bdMeetings.textContent = String(meetingsPerMonth);
    if (bdPolicies) bdPolicies.textContent = String(policies);

    // Animate the number
    if (calcResult) {
      const current = parseInt(calcResult.textContent?.replace(/,/g, '') || '0');
      gsap.to({ val: current }, {
        val: income,
        duration: 0.5,
        ease: 'power2.out',
        onUpdate: function() {
          if (calcResult) {
            calcResult.textContent = Math.round(this.targets()[0].val).toLocaleString('en-MY');
          }
        }
      });
    }
  }

  contactsSlider?.addEventListener('input', updateCalc);
  hoursSlider?.addEventListener('input', updateCalc);
  updateCalc(); // init

  // FAQ accordion
  document.querySelectorAll('.faq-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const answer = item?.querySelector('.faq-answer') as HTMLElement;
      const icon = btn.querySelector('.faq-icon') as HTMLElement;

      const isOpen = answer?.style.maxHeight && answer.style.maxHeight !== '0px';

      // Close all
      document.querySelectorAll('.faq-answer').forEach((a: any) => { a.style.maxHeight = '0'; });
      document.querySelectorAll('.faq-icon').forEach((i: any) => { i.style.transform = 'rotate(0)'; i.textContent = '+'; });

      if (!isOpen && answer) {
        answer.style.maxHeight = answer.scrollHeight + 'px';
        if (icon) { icon.style.transform = 'rotate(45deg)'; }
      }
    });
  });

  // Apply form submission
  const applyForm = document.getElementById('apply-form') as HTMLFormElement;
  applyForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('submit-btn') as HTMLButtonElement;
    const success = document.getElementById('form-success');
    const error = document.getElementById('form-error');

    btn.textContent = 'Sending...';
    btn.style.opacity = '0.7';
    btn.disabled = true;

    const formData = new FormData(applyForm);
    const data = Object.fromEntries(formData.entries());

    try {
      const res = await fetch('/api/apply', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });

      if (res.ok) {
        applyForm.style.display = 'none';
        if (success) success.style.display = 'block';
      } else {
        throw new Error('Server error');
      }
    } catch {
      btn.textContent = 'Send — let\'s talk →';
      btn.style.opacity = '1';
      btn.disabled = false;
      if (error) error.style.display = 'block';
    }
  });

  // Bounce animation for scroll indicator
  const style = document.createElement('style');
  style.textContent = `
    @keyframes bounce { 0%,100%{transform:translateX(-50%) translateY(0)} 50%{transform:translateX(-50%) translateY(-8px)} }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
  `;
  document.head.appendChild(style);
</script>
