---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- ===== NAV ===== -->
  <nav id="nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" style="background: transparent;">
    <div class="max-w-6xl mx-auto px-6 py-5 flex items-center justify-between">
      <a href="/" class="font-bold text-xl" style="font-family: 'Space Grotesk', sans-serif; color: #111;">
        not<span style="color: #d4a800;">bad</span>lah<span style="color: #d4a800;">.</span>
      </a>
      <a href="#apply"
        class="hidden sm:inline-flex items-center gap-2 px-5 py-2 rounded-full text-sm font-semibold transition-all duration-200 hover:opacity-80"
        style="background: #111111; color: #ffffff;">
        Find Out More
      </a>
    </div>
  </nav>

  <!-- ===== HERO ===== -->
  <section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden" style="padding: 120px 24px 80px; background: #ffffff;">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 70% 50% at 50% 0%, rgba(255,225,53,0.12) 0%, transparent 70%);"></div>

    <div class="relative z-10 max-w-5xl mx-auto text-center">
      <!-- Tag -->
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-8 text-sm font-medium"
        style="background: #FFF8D0; border: 1px solid #FFE135; color: #996600;">
        <span style="width:6px;height:6px;border-radius:50%;background:#d4a800;display:inline-block;"></span>
        Part-time opportunity in Malaysia
      </div>

      <!-- Main headline -->
      <h1 id="hero-h1" style="font-size: clamp(2.8rem, 8vw, 7rem); line-height: 1.05; letter-spacing: -0.03em; margin-bottom: 24px; color: #111;">
        Extra&nbsp;<span style="color: #d4a800;">RM5,000</span><br />
        a month.<br />
        <span style="color: #aaa;">Part&#8209;time.</span>
      </h1>

      <p id="hero-p" style="font-size: clamp(1rem, 2.5vw, 1.25rem); color: #666; max-width: 500px; margin: 0 auto 40px; line-height: 1.7;">
        We walked up to strangers and told them. Most said "cannot lah."
        After we showed them the math, they changed their tune.
      </p>

      <div id="hero-cta" class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="#calculator"
          class="px-8 py-4 rounded-full font-semibold text-base transition-all duration-200 hover:scale-105"
          style="background: #111111; color: #ffffff;">
          Calculate My Income
        </a>
        <a href="#how-it-works"
          class="px-8 py-4 rounded-full font-semibold text-base transition-all duration-200 hover:border-gray-400"
          style="border: 1px solid #ddd; color: #666;">
          How does it work?
        </a>
      </div>

      <!-- Proof numbers -->
      <div id="hero-stats" class="grid grid-cols-3 gap-4 mt-20 max-w-2xl mx-auto">
        {[
          { num: "1,800+", label: "Part-time agents in Malaysia" },
          { num: "RM750", label: "Avg. commission per policy" },
          { num: "#1", label: "Insurance company in Malaysia" }
        ].map(item => (
          <div class="text-center">
            <div class="tabular" style="font-family:'Space Grotesk',sans-serif; font-size: clamp(1.5rem,4vw,2.5rem); font-weight:800; color:#d4a800;">{item.num}</div>
            <div style="font-size:0.75rem; color:#999; margin-top:4px;">{item.label}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2" style="animation: bounce 2s infinite;">
      <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#bbb" stroke-width="2">
        <path d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </section>

  <!-- ===== THE REACTION (Story Section) ===== -->
  <section id="the-story" class="py-24 px-6" style="max-width: 800px; margin: 0 auto;">
    <div class="text-center mb-16">
      <p style="color:#d4a800;font-size:0.875rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:12px;">The Concept</p>
      <h2 style="font-size: clamp(2rem, 5vw, 3.5rem); line-height: 1.1; color: #111;">This is how the conversation goes</h2>
    </div>

    <div id="chat-container" class="space-y-6">
      <div class="chat-msg flex items-end gap-3 fade-up">
        <div class="w-9 h-9 rounded-full flex-shrink-0 flex items-center justify-center text-xs font-bold"
          style="background: #FFE135; color: #111; font-family: 'Space Grotesk',sans-serif;">C</div>
        <div class="bubble-left px-5 py-3 max-w-sm" style="background: #f0f0f0; color: #111;">
          <p style="font-size: 0.95rem;">Hey, random question. What do you do for work?</p>
        </div>
      </div>

      <div class="chat-msg flex items-end gap-3 justify-end fade-up">
        <div class="bubble-right px-5 py-3 max-w-sm" style="background: #FFF8D0; color: #111; border: 1px solid #FFE135;">
          <p style="font-size: 0.95rem;">I'm a teacher. Why ah?</p>
        </div>
        <div class="w-9 h-9 rounded-full flex-shrink-0 flex items-center justify-center text-xs font-bold"
          style="background: #e8e8e8; color: #555;">?</div>
      </div>

      <div class="chat-msg flex items-end gap-3 fade-up">
        <div class="w-9 h-9 rounded-full flex-shrink-0 flex items-center justify-center text-xs font-bold"
          style="background: #FFE135; color: #111; font-family: 'Space Grotesk',sans-serif;">C</div>
        <div class="bubble-left px-5 py-3 max-w-sm" style="background: #f0f0f0; color: #111;">
          <p style="font-size: 0.95rem;">Nice. Did you know that part-time, on the side, you can add RM5,000 to your income every month?</p>
        </div>
      </div>

      <div class="chat-msg flex items-end gap-3 justify-end fade-up">
        <div class="bubble-right px-5 py-3 max-w-sm" style="background: #FFF8D0; color: #111; border: 1px solid #FFE135;">
          <p style="font-size: 0.95rem;">Eh? MLM ke? 😒</p>
        </div>
        <div class="w-9 h-9 rounded-full flex-shrink-0 flex items-center justify-center text-xs font-bold"
          style="background: #e8e8e8; color: #555;">?</div>
      </div>

      <div class="chat-msg flex items-end gap-3 fade-up">
        <div class="w-9 h-9 rounded-full flex-shrink-0 flex items-center justify-center text-xs font-bold"
          style="background: #FFE135; color: #111; font-family: 'Space Grotesk',sans-serif;">C</div>
        <div class="bubble-left px-5 py-3 max-w-sm" style="background: #f0f0f0; color: #111;">
          <p style="font-size: 0.95rem;">Bukan. AIA Malaysia. Bursa-listed company. You help people protect their income, they pay you a commission. Simple.</p>
        </div>
      </div>

      <div class="chat-msg flex items-end gap-3 justify-end fade-up">
        <div class="bubble-right px-5 py-3 max-w-sm" style="background: #FFF8D0; color: #111; border: 1px solid #FFE135;">
          <p style="font-size: 0.95rem;">But I have no experience. And I'm shy lah...</p>
        </div>
        <div class="w-9 h-9 rounded-full flex-shrink-0 flex items-center justify-center text-xs font-bold"
          style="background: #e8e8e8; color: #555;">?</div>
      </div>

      <div class="chat-msg flex items-end gap-3 fade-up">
        <div class="w-9 h-9 rounded-full flex-shrink-0 flex items-center justify-center text-xs font-bold"
          style="background: #FFE135; color: #111; font-family: 'Space Grotesk',sans-serif;">C</div>
        <div class="bubble-left px-5 py-3 max-w-sm" style="background: #f0f0f0; color: #111;">
          <p style="font-size: 0.95rem;">We train you. You don't need to be a salesperson. Just help people you already know. 10 hours a week is enough to start.</p>
        </div>
      </div>

      <div class="chat-msg flex items-end gap-3 justify-end fade-up">
        <div class="bubble-right px-5 py-3 max-w-sm" style="background: #FFF8D0; color: #111; border: 1px solid #FFE135;">
          <p style="font-size: 0.95rem;">Hmm. But RM5,000 every month? Really can meh?</p>
        </div>
        <div class="w-9 h-9 rounded-full flex-shrink-0 flex items-center justify-center text-xs font-bold"
          style="background: #e8e8e8; color: #555;">?</div>
      </div>

      <div class="chat-msg flex items-end gap-3 fade-up">
        <div class="w-9 h-9 rounded-full flex-shrink-0 flex items-center justify-center text-xs font-bold"
          style="background: #FFE135; color: #111; font-family: 'Space Grotesk',sans-serif;">C</div>
        <div class="bubble-left px-5 py-3 max-w-sm" style="background: #f0f0f0; color: #111;">
          <p style="font-size: 0.95rem;">6 to 7 policies a month. Average RM750 commission each. You do the math 😏</p>
        </div>
      </div>

      <!-- Final reaction -->
      <div class="chat-msg flex items-end gap-3 justify-end fade-up">
        <div class="bubble-right px-5 py-4 max-w-sm" style="background: #FFE135; color: #111; border: 1px solid #d4a800;">
          <p style="font-size: 1.1rem; font-weight: 700;">"Insurance... not bad lah! 🤙"</p>
        </div>
        <div class="w-9 h-9 rounded-full flex-shrink-0 flex items-center justify-center text-xs font-bold"
          style="background: #e8e8e8; color: #555;">?</div>
      </div>
    </div>

    <div class="text-center mt-14">
      <p style="color: #999; font-size: 0.9rem;">Want to see the actual numbers?</p>
      <a href="#calculator" class="inline-block mt-4 px-8 py-3 rounded-full font-semibold transition-all hover:scale-105"
        style="background: #111; color: #fff;">
        Try the income calculator
      </a>
    </div>
  </section>

  <!-- ===== INCOME CALCULATOR ===== -->
  <section id="calculator" class="py-24 px-6" style="background: #f9f9f9;">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-14 fade-up">
        <p style="color:#d4a800;font-size:0.875rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:12px;">Income Calculator</p>
        <h2 style="font-size: clamp(2rem, 5vw, 3.5rem); line-height: 1.1;">See what you could earn</h2>
        <p style="color: #888; margin-top: 12px; font-size: 0.95rem;">Based on real AIA commission structures</p>
      </div>

      <div class="glow-card rounded-2xl p-8 fade-up" style="background: #fff;">
        <!-- Slider 1 -->
        <div class="mb-10">
          <div class="flex justify-between items-end mb-4">
            <label style="font-family:'Space Grotesk',sans-serif; font-size: 1.1rem; font-weight: 600; color: #111;">
              People you can reach per week
            </label>
            <span id="contacts-display" style="font-size:1.5rem;font-weight:800;color:#d4a800;font-family:'Space Grotesk',sans-serif;">0</span>
          </div>
          <input type="range" id="contacts-slider" min="0" max="30" value="0" step="1" />
          <div class="flex justify-between mt-2" style="color: #bbb; font-size: 0.75rem;">
            <span>0 (no effort)</span>
            <span>30 people/week</span>
          </div>
        </div>

        <!-- Slider 2 -->
        <div class="mb-10">
          <div class="flex justify-between items-end mb-4">
            <label style="font-family:'Space Grotesk',sans-serif; font-size: 1.1rem; font-weight: 600; color: #111;">
              Hours per week you can spare
            </label>
            <span id="hours-display" style="font-size:1.5rem;font-weight:800;color:#d4a800;font-family:'Space Grotesk',sans-serif;">0</span>
          </div>
          <input type="range" id="hours-slider" min="0" max="30" value="0" step="1" />
          <div class="flex justify-between mt-2" style="color: #bbb; font-size: 0.75rem;">
            <span>0 (no effort)</span>
            <span>30 hrs/week</span>
          </div>
        </div>

        <!-- Result -->
        <div class="rounded-xl p-6 text-center" style="background: #f9f9f9; border: 1px solid #e8e8e8;">
          <p style="color: #888; font-size: 0.875rem; margin-bottom: 8px;">Your estimated monthly income</p>
          <div class="tabular" style="font-family:'Space Grotesk',sans-serif; font-size: clamp(3rem,8vw,5rem); font-weight:800; color:#111; line-height:1;">
            RM<span id="calc-result">0</span>
          </div>
          <p style="color: #aaa; font-size: 0.8rem; margin-top: 8px;">per month, part-time</p>
        </div>

        <!-- Breakdown -->
        <div id="calc-breakdown" class="mt-6 grid grid-cols-3 gap-4 text-center">
          <div style="background:#f5f5f5;border-radius:12px;padding:16px;border:1px solid #eee;">
            <div id="bd-meetings" style="font-family:'Space Grotesk',sans-serif;font-size:1.5rem;font-weight:700;color:#111;">0</div>
            <div style="color:#aaa;font-size:0.75rem;margin-top:4px;">meetings/month</div>
          </div>
          <div style="background:#f5f5f5;border-radius:12px;padding:16px;border:1px solid #eee;">
            <div id="bd-policies" style="font-family:'Space Grotesk',sans-serif;font-size:1.5rem;font-weight:700;color:#111;">0</div>
            <div style="color:#aaa;font-size:0.75rem;margin-top:4px;">policies/month</div>
          </div>
          <div style="background:#f5f5f5;border-radius:12px;padding:16px;border:1px solid #eee;">
            <div id="bd-commission" style="font-family:'Space Grotesk',sans-serif;font-size:1.5rem;font-weight:700;color:#111;">RM750</div>
            <div style="color:#aaa;font-size:0.75rem;margin-top:4px;">avg per policy</div>
          </div>
        </div>

        <p style="text-align:center;color:#ccc;font-size:0.75rem;margin-top:16px;">
          Estimates based on 20% conversion rate and RM750 avg. first-year commission. Individual results will vary.
        </p>
      </div>

      <div class="text-center mt-8">
        <a href="#apply" class="inline-block px-8 py-4 rounded-full font-semibold transition-all hover:scale-105"
          style="background: #111; color: #fff;">
          I want these numbers. Let me in.
        </a>
      </div>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section id="how-it-works" class="py-24 px-6" style="background: #fff;">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16 fade-up">
        <p style="color:#d4a800;font-size:0.875rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:12px;">The Process</p>
        <h2 style="font-size: clamp(2rem, 5vw, 3.5rem); line-height: 1.1;">From zero to first commission<br />in 30 days</h2>
      </div>

      <div class="grid md:grid-cols-4 gap-6">
        {[
          { step: "01", title: "Register", desc: "Sign up as an AIA part-time Financial Advisor. Takes less than 10 minutes online.", tag: "Free" },
          { step: "02", title: "Get Certified", desc: "Complete your PCE (Pre-Contract Exam). We guide you through it. Most pass in 2 weeks.", tag: "2 weeks" },
          { step: "03", title: "Get Trained", desc: "Two-day onboarding with our team. Learn how to have real conversations, not hard selling.", tag: "Day 15" },
          { step: "04", title: "First Commission", desc: "Close your first policy. Earn your first RM750 to RM1,200. It usually happens faster than you expect.", tag: "Day 30+" }
        ].map((item, i) => (
          <div class="glow-card rounded-xl p-6 fade-up" style={`animation-delay: ${i * 0.1}s`}>
            <div style="font-size:0.75rem;font-weight:700;color:#d4a800;margin-bottom:16px;font-family:'Space Grotesk',sans-serif;">
              STEP {item.step}
            </div>
            <div class="inline-block px-3 py-1 rounded-full text-xs font-semibold mb-4"
              style="background: #FFF8D0; color: #996600; border: 1px solid #FFE135;">
              {item.tag}
            </div>
            <h3 style="font-size:1.25rem;font-family:'Space Grotesk',sans-serif;font-weight:700;margin-bottom:8px;color:#111;">{item.title}</h3>
            <p style="color:#777;font-size:0.875rem;line-height:1.7;">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section id="faq" class="py-24 px-6" style="background: #f9f9f9;">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-14 fade-up">
        <p style="color:#d4a800;font-size:0.875rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:12px;">Real Talk</p>
        <h2 style="font-size: clamp(2rem, 5vw, 3.5rem); line-height: 1.1;">Your questions.<br />Honest answers.</h2>
      </div>

      <div class="space-y-3" id="faq-list">
        {[
          {
            q: "Is this MLM?",
            a: "No. AIA (AIA Berhad) is listed on Bursa Malaysia. It has been operating in Malaysia for over 80 years. You are a licensed Financial Advisor registered with Bank Negara, not a downline."
          },
          {
            q: "Do I need experience?",
            a: "Zero experience needed. All you need to start is a SPM cert and a willingness to learn. We provide full training and personally mentor everyone in our team."
          },
          {
            q: "Do I have to sell to family and friends?",
            a: "Not at all. We teach you how to prospect professionally, from your network and beyond. Many of our agents don't sell a single policy to family."
          },
          {
            q: "Is there a quota I have to hit?",
            a: "No quota as a part-time agent. You work at your own pace. But the more consistent you are, the faster you grow."
          },
          {
            q: "How long before I see real money?",
            a: "Most agents on our team close their first policy within their first 2 to 4 weeks. Your first commission could land in your account within 30 days of registering."
          },
          {
            q: "Can I do this while working full-time?",
            a: "Yes, that's the whole point. Most of our agents started part-time while keeping their day jobs. 10 hours a week is enough to get started."
          },
          {
            q: "Why AIA specifically?",
            a: "AIA Malaysia has the widest product range, strongest brand trust, and best support system for new agents. Most Malaysians already know and trust AIA, which makes conversations easier."
          }
        ].map((item, i) => (
          <div class="faq-item glow-card rounded-xl overflow-hidden fade-up" style={`animation-delay: ${i * 0.05}s; background: #fff;`} data-index={i}>
            <button class="faq-toggle w-full flex justify-between items-center p-6 text-left"
              style="background: none; border: none; color: #111; cursor: pointer; font-family: 'Space Grotesk', sans-serif;">
              <span style="font-size:1rem;font-weight:600;">{item.q}</span>
              <span class="faq-icon ml-4 flex-shrink-0" style="color: #d4a800; font-size: 1.2rem; transition: transform 0.3s;">+</span>
            </button>
            <div class="faq-answer" style="max-height:0;overflow:hidden;transition:max-height 0.4s ease;">
              <p style="padding:0 24px 24px;color:#666;font-size:0.9rem;line-height:1.8;">{item.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== APPLY FORM ===== -->
  <section id="apply" class="py-24 px-6" style="background: #fff;">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-12 fade-up">
        <p style="color:#d4a800;font-size:0.875rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:12px;">Get Started</p>
        <h2 style="font-size:clamp(2rem,5vw,3.5rem);line-height:1.1;">Tell us about yourself.<br />No pressure.</h2>
        <p style="color:#888;margin-top:12px;font-size:0.95rem;">We'll reach out within 24 hours to set up a casual chat.</p>
      </div>

      <form id="apply-form" class="glow-card rounded-2xl p-8 fade-up" method="POST" action="/api/apply" novalidate style="background: #fff;">
        <div class="space-y-5">
          <div>
            <label style="display:block;font-size:0.875rem;font-weight:500;color:#666;margin-bottom:8px;">Full Name *</label>
            <input type="text" name="name" required placeholder="Your name"
              style="width:100%;padding:12px 16px;background:#f9f9f9;border:1px solid #e0e0e0;border-radius:10px;color:#111;font-size:0.95rem;outline:none;transition:border-color 0.2s;"
              onfocus="this.style.borderColor='#d4a800'" onblur="this.style.borderColor='#e0e0e0'"
            />
          </div>

          <div>
            <label style="display:block;font-size:0.875rem;font-weight:500;color:#666;margin-bottom:8px;">Phone Number (WhatsApp) *</label>
            <input type="tel" name="phone" required placeholder="e.g. 012-3456789"
              style="width:100%;padding:12px 16px;background:#f9f9f9;border:1px solid #e0e0e0;border-radius:10px;color:#111;font-size:0.95rem;outline:none;transition:border-color 0.2s;"
              onfocus="this.style.borderColor='#d4a800'" onblur="this.style.borderColor='#e0e0e0'"
            />
          </div>

          <div>
            <label style="display:block;font-size:0.875rem;font-weight:500;color:#666;margin-bottom:8px;">Email Address *</label>
            <input type="email" name="email" required placeholder="you@email.com"
              style="width:100%;padding:12px 16px;background:#f9f9f9;border:1px solid #e0e0e0;border-radius:10px;color:#111;font-size:0.95rem;outline:none;transition:border-color 0.2s;"
              onfocus="this.style.borderColor='#d4a800'" onblur="this.style.borderColor='#e0e0e0'"
            />
          </div>

          <div>
            <label style="display:block;font-size:0.875rem;font-weight:500;color:#666;margin-bottom:8px;">Current Occupation</label>
            <input type="text" name="occupation" placeholder="e.g. Teacher, Engineer, Student..."
              style="width:100%;padding:12px 16px;background:#f9f9f9;border:1px solid #e0e0e0;border-radius:10px;color:#111;font-size:0.95rem;outline:none;transition:border-color 0.2s;"
              onfocus="this.style.borderColor='#d4a800'" onblur="this.style.borderColor='#e0e0e0'"
            />
          </div>

          <div>
            <label style="display:block;font-size:0.875rem;font-weight:500;color:#666;margin-bottom:8px;">Hours available per week</label>
            <select name="hours_available"
              style="width:100%;padding:12px 16px;background:#f9f9f9;border:1px solid #e0e0e0;border-radius:10px;color:#111;font-size:0.95rem;outline:none;transition:border-color 0.2s;cursor:pointer;"
              onfocus="this.style.borderColor='#d4a800'" onblur="this.style.borderColor='#e0e0e0'"
            >
              <option value="">Select...</option>
              <option value="5-10">5 to 10 hours</option>
              <option value="10-20">10 to 20 hours</option>
              <option value="20+">20+ hours (serious!)</option>
            </select>
          </div>

          <button type="submit" id="submit-btn"
            class="w-full py-4 rounded-xl font-semibold text-base transition-all duration-200 hover:opacity-80"
            style="background: #111; color: #fff; font-family: 'Space Grotesk',sans-serif; cursor: pointer; border: none;">
            Send. Let's talk.
          </button>

          <div id="form-success" style="display:none;text-align:center;padding:16px;background:#FFF8D0;border:1px solid #FFE135;border-radius:10px;color:#996600;font-size:0.9rem;">
            Done! We'll reach out within 24 hours.
          </div>
          <div id="form-error" style="display:none;text-align:center;padding:16px;background:#fff0f0;border:1px solid #ffcccc;border-radius:10px;color:#cc3333;font-size:0.9rem;">
            Something went wrong. Please try again.
          </div>
        </div>
      </form>
    </div>
  </section>

  <!-- ===== FOOTER ===== -->
  <footer class="py-10 px-6" style="border-top: 1px solid #eee; background: #fff;">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="font-bold text-lg" style="font-family: 'Space Grotesk', sans-serif; color: #111;">
        not<span style="color: #d4a800;">bad</span>lah<span style="color: #d4a800;">.</span>com
      </div>
      <p style="color: #aaa; font-size: 0.8rem; text-align: center;">
        An authorised AIA agency in Malaysia. Proudly Malaysian 🇲🇾
      </p>
      <p style="color: #ccc; font-size: 0.75rem;">
        &copy; 2026 notbadlah.com
      </p>
    </div>
  </footer>
</Layout>

<!-- ===== SCRIPTS ===== -->
<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Nav scroll effect
  const nav = document.getElementById('nav');
  ScrollTrigger.create({
    start: 'top -80',
    onUpdate: (self) => {
      if (nav) {
        nav.style.background = self.progress > 0 ? 'rgba(255,255,255,0.95)' : 'transparent';
        nav.style.backdropFilter = self.progress > 0 ? 'blur(12px)' : 'none';
        nav.style.borderBottom = self.progress > 0 ? '1px solid #eee' : 'none';
      }
    }
  });

  // Scroll-triggered fade-up for below-fold elements
  gsap.utils.toArray('.fade-up').forEach((el: any) => {
    gsap.fromTo(el,
      { opacity: 0, y: 40 },
      {
        opacity: 1, y: 0,
        duration: 0.8,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 88%',
          toggleActions: 'play none none none'
        }
      }
    );
  });

  // Hero entrance
  const heroTl = gsap.timeline({ delay: 0.1 });
  heroTl
    .fromTo('#hero-h1',    { opacity: 0, y: 60 }, { opacity: 1, y: 0, duration: 1.1, ease: 'power4.out' })
    .fromTo('#hero-p',     { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 0.9, ease: 'power3.out' }, '-=0.7')
    .fromTo('#hero-cta',   { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' }, '-=0.6')
    .fromTo('#hero-stats', { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' }, '-=0.5');

  // Chat messages stagger
  ScrollTrigger.create({
    trigger: '#chat-container',
    start: 'top 70%',
    onEnter: () => {
      gsap.utils.toArray('.chat-msg').forEach((el: any, i) => {
        gsap.fromTo(el,
          { opacity: 0, x: el.classList.contains('justify-end') ? 40 : -40 },
          { opacity: 1, x: 0, duration: 0.5, delay: i * 0.15, ease: 'power2.out' }
        );
      });
    }
  });

  // Income calculator
  const contactsSlider = document.getElementById('contacts-slider') as HTMLInputElement;
  const hoursSlider    = document.getElementById('hours-slider')    as HTMLInputElement;
  const contactsDisplay = document.getElementById('contacts-display');
  const hoursDisplay    = document.getElementById('hours-display');
  const calcResult  = document.getElementById('calc-result');
  const bdMeetings  = document.getElementById('bd-meetings');
  const bdPolicies  = document.getElementById('bd-policies');

  function updateCalc() {
    const contacts = parseInt(contactsSlider?.value || '0');
    const hours    = parseInt(hoursSlider?.value    || '0');

    if (contactsDisplay) contactsDisplay.textContent = String(contacts);
    if (hoursDisplay)    hoursDisplay.textContent    = String(hours);

    // Zero effort = zero income
    if (contacts === 0 || hours === 0) {
      if (bdMeetings) bdMeetings.textContent = '0';
      if (bdPolicies) bdPolicies.textContent = '0';
      if (calcResult) {
        gsap.to({ val: parseInt(calcResult.textContent?.replace(/,/g,'') || '0') }, {
          val: 0, duration: 0.4, ease: 'power2.out',
          onUpdate: function() {
            if (calcResult) calcResult.textContent = Math.round(this.targets()[0].val).toLocaleString('en-MY');
          }
        });
      }
      return;
    }

    const meetingsPerMonth = Math.round(contacts * 4.3);
    const conversionRate   = Math.min(0.20 + (hours - 1) * 0.003, 0.30);
    const policies         = Math.max(1, Math.round(meetingsPerMonth * conversionRate));
    const income           = policies * 750;

    if (bdMeetings) bdMeetings.textContent = String(meetingsPerMonth);
    if (bdPolicies) bdPolicies.textContent = String(policies);

    if (calcResult) {
      const current = parseInt(calcResult.textContent?.replace(/,/g, '') || '0');
      gsap.to({ val: current }, {
        val: income, duration: 0.5, ease: 'power2.out',
        onUpdate: function() {
          if (calcResult) calcResult.textContent = Math.round(this.targets()[0].val).toLocaleString('en-MY');
        }
      });
    }
  }

  contactsSlider?.addEventListener('input', updateCalc);
  hoursSlider?.addEventListener('input', updateCalc);
  updateCalc(); // init — sliders at 0, shows RM0

  // FAQ accordion
  document.querySelectorAll('.faq-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const item   = btn.closest('.faq-item');
      const answer = item?.querySelector('.faq-answer') as HTMLElement;
      const icon   = btn.querySelector('.faq-icon') as HTMLElement;
      const isOpen = answer?.style.maxHeight && answer.style.maxHeight !== '0px';

      document.querySelectorAll('.faq-answer').forEach((a: any) => { a.style.maxHeight = '0'; });
      document.querySelectorAll('.faq-icon').forEach((i: any) => { i.style.transform = 'rotate(0)'; i.textContent = '+'; });

      if (!isOpen && answer) {
        answer.style.maxHeight = answer.scrollHeight + 'px';
        if (icon) icon.style.transform = 'rotate(45deg)';
      }
    });
  });

  // Apply form
  const applyForm = document.getElementById('apply-form') as HTMLFormElement;
  applyForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn     = document.getElementById('submit-btn') as HTMLButtonElement;
    const success = document.getElementById('form-success');
    const error   = document.getElementById('form-error');

    btn.textContent = 'Sending...';
    btn.style.opacity = '0.6';
    btn.disabled = true;

    const data = Object.fromEntries(new FormData(applyForm).entries());

    try {
      const res = await fetch('/api/apply', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      if (res.ok) {
        applyForm.style.display = 'none';
        if (success) success.style.display = 'block';
      } else {
        throw new Error('error');
      }
    } catch {
      btn.textContent = 'Send. Let\'s talk.';
      btn.style.opacity = '1';
      btn.disabled = false;
      if (error) error.style.display = 'block';
    }
  });

  // Animations
  const style = document.createElement('style');
  style.textContent = `@keyframes bounce { 0%,100%{transform:translateX(-50%) translateY(0)} 50%{transform:translateX(-50%) translateY(-8px)} }`;
  document.head.appendChild(style);
</script>
